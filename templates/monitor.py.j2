import meshtastic
from meshtastic.tcp_interface import TCPInterface
from meshtastic.serial_interface import SerialInterface
from pubsub import pub
from datetime import datetime
import time
import threading
import importlib
import os

CONNECTION_TYPE = "{{ meshtastic_connection }}"
HOST = "{{ meshtastic_host | default('') }}"
PORT = "{{ meshtastic_port | default('') }}"

TELEMETRY_ENABLED = {{ telemetry_enabled | default(True) }}
TELEMETRY_INTERVAL = int("{{ telemetry_interval | default(300) }}")

LOCAL_NODE_ID = "{{ local_node_id | default('') }}"
BASE_PATH = "{{ monitor_home }}"

DEVICE_LOG = os.path.join(BASE_PATH, "device.log")


def now_local_str():
    dt = datetime.now().astimezone()
    tz = dt.strftime("%Z")
    off = dt.strftime("%z")
    off = f"{off[:3]}:{off[3:]}" if off else ""
    return dt.strftime("%Y-%m-%d %H:%M:%S") + f" {tz} ({off})"


def log_system(msg):
    line = f"{now_local_str()} type=SYSTEM node={LOCAL_NODE_ID} msg={msg}"
    with open(DEVICE_LOG, "a") as f:
        f.write(line + "\n")


# --- Detect restart vs start ---
if os.path.exists(DEVICE_LOG):
    log_system("RESTARTING meshtastic-monitor")
else:
    log_system("STARTING meshtastic-monitor")


MODULES = [
    ("mesh_logger", True),
    ("device_logger", {{ device_enabled | default(True) }}),
    ("telemetry_logger", {{ telemetry_enabled | default(True) }}),
    ("environment_logger", {{ environment_enabled | default(True) }}),
]

loaded_modules = []

for name, enabled in MODULES:
    if not enabled:
        continue
    mod = importlib.import_module(f"modules.{name}")
    loaded_modules.append(mod)
    log_system(f"module_loaded={name}")


def on_receive(packet, interface=None):
    for mod in loaded_modules:
        mod.handle(packet, BASE_PATH, LOCAL_NODE_ID)


def telemetry_loop(interface):
    while True:
        try:
            interface.sendTelemetry()
        except Exception:
            pass
        time.sleep(TELEMETRY_INTERVAL)


if CONNECTION_TYPE.lower() == "tcp":
    iface = TCPInterface(hostname=HOST)
else:
    iface = SerialInterface(PORT)


pub.subscribe(on_receive, "meshtastic.receive")


if TELEMETRY_ENABLED:
    threading.Thread(target=telemetry_loop, args=(iface,), daemon=True).start()


log_system(f"connected={CONNECTION_TYPE}")


while True:
    time.sleep(3600)
