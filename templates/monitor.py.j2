import meshtastic
from meshtastic.tcp_interface import TCPInterface
from meshtastic.serial_interface import SerialInterface
from pubsub import pub
from datetime import datetime
import time
import threading
import importlib

CONNECTION_TYPE = "{{ meshtastic_connection }}"
HOST = "{{ meshtastic_host | default('') }}"
PORT = "{{ meshtastic_port | default('') }}"

LOCAL_NODE_ID = "{{ local_node_id | default('') }}"
BASE_PATH = "{{ monitor_home }}"

# --- ENABLE FLAGS ---
DEVICE_ENABLED = {{ device_enabled | default(True) }}
TELEMETRY_ENABLED = {{ telemetry_enabled | default(True) }}
ENVIRONMENT_ENABLED = {{ environment_enabled | default(True) }}
POSITION_ENABLED = {{ position_enabled | default(False) }}
NODEINFO_ENABLED = {{ nodeinfo_enabled | default(True) }}
TEXT_ENABLED = {{ text_enabled | default(True) }}
UNKNOWN_ENABLED = {{ unknown_enabled | default(True) }}

# --- INTERVALS ---
DEVICE_INTERVAL = {{ device_interval | default(300) }}
TELEMETRY_INTERVAL = {{ telemetry_interval | default(300) }}
ENVIRONMENT_INTERVAL = {{ environment_log_interval | default(300) }}
POSITION_INTERVAL = {{ position_interval | default(300) }}
NODEINFO_INTERVAL = {{ nodeinfo_interval | default(300) }}
TEXT_INTERVAL = {{ text_interval | default(0) }}        # 0 = realtime
UNKNOWN_INTERVAL = {{ unknown_interval | default(0) }}  # 0 = realtime


def now_record(msg):
    dt = datetime.now().astimezone()
    return {
        "timestamp": dt.isoformat(),
        "type": "system",
        "node_id": LOCAL_NODE_ID,
        "data": {"message": msg}
    }


def write_system(msg):
    from modules.common_logger import write
    write(BASE_PATH, "system", now_record(msg))


write_system("STARTING meshtastic-monitor")

MODULES = [
    ("device_logger", DEVICE_ENABLED),
    ("telemetry_logger", TELEMETRY_ENABLED),
    ("environment_logger", ENVIRONMENT_ENABLED),
    ("nodeinfo_logger", NODEINFO_ENABLED),
    ("text_logger", TEXT_ENABLED),
    ("position_logger", POSITION_ENABLED),
    ("unknown_logger", UNKNOWN_ENABLED),
]

loaded_modules = []

for name, enabled in MODULES:
    if not enabled:
        continue
    mod = importlib.import_module(f"modules.{name}")

    # pass interval config if module supports it
    if hasattr(mod, "set_config"):
        mod.set_config({
            "interval": globals().get(f"{name.split('_')[0].upper()}_INTERVAL", 0)
        })

    loaded_modules.append(mod)
    write_system(f"module_loaded={name}")


def on_receive(packet, interface=None):
    for mod in loaded_modules:
        mod.handle(packet, BASE_PATH, LOCAL_NODE_ID)


if CONNECTION_TYPE.lower() == "tcp":
    iface = TCPInterface(hostname=HOST)
else:
    iface = SerialInterface(PORT)


pub.subscribe(on_receive, "meshtastic.receive")


write_system(f"connected={CONNECTION_TYPE}")


while True:
    time.sleep(3600)
