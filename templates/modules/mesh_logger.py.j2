from modules.common_logger import write, ts

def handle(packet, base_path, local_node_id):
    d = packet.get("decoded", {})
    port = d.get("portnum")
    node_id = packet.get("fromId") or packet.get("from")
    snr = packet.get("rxSnr")
    rssi = packet.get("rxRssi")

    if not node_id:
        return

    # --- EXCLUDE LOCAL NODE ---
    if node_id == local_node_id:
        return

    dt = ts()

    # --- TELEMETRY ---
    if port == "TELEMETRY_APP":
        t = d.get("telemetry", {}).get("deviceMetrics", {})

        record = {
            "timestamp": dt.isoformat(),
            "type": "TELEM",
            "node_id": node_id,
            "data": {
                "battery": t.get("batteryLevel"),
                "voltage": t.get("voltage"),
                "snr": snr,
                "rssi": rssi
            }
        }

        write(base_path, "mesh", record)

    # --- NODEINFO ---
    elif port == "NODEINFO_APP":
        u = d.get("user", {})

        record = {
            "timestamp": dt.isoformat(),
            "type": "NODE",
            "node_id": node_id,
            "data": {
                "name": u.get("longName"),
                "role": u.get("role"),
                "hw_model": u.get("hwModel"),
                "snr": snr,
                "rssi": rssi
            }
        }

        write(base_path, "mesh", record)

    # --- TEXT ---
    elif port == "TEXT_MESSAGE_APP":
        txt = d.get("text", "")

        record = {
            "timestamp": dt.isoformat(),
            "type": "TEXT",
            "node_id": node_id,
            "data": {
                "message": txt,
                "snr": snr,
                "rssi": rssi
            }
        }

        write(base_path, "mesh", record)
