import time
from modules.common_logger import write, ts

CONFIG = {"interval": {{ device_interval | default(300) }}}
last_write = {}

def set_config(cfg):
    CONFIG.update(cfg)

def handle(packet, base_path, local_node_id):
    d = packet.get("decoded", {})
    if d.get("portnum") != "TELEMETRY_APP":
        return

    node_id = packet.get("fromId") or packet.get("from")
    if node_id != local_node_id:
        return

    now = time.time()
    last = last_write.get(node_id, 0)
    if CONFIG["interval"] > 0 and (now - last) < CONFIG["interval"]:
        return

    dm = d.get("telemetry", {}).get("deviceMetrics", {})
    if not dm:
        return

    record = {
        "timestamp": ts().isoformat(),
        "type": "device",
        "node_id": node_id,
        "data": {
            "battery": dm.get("batteryLevel"),
            "voltage": dm.get("voltage"),
            "uptime_seconds": dm.get("uptimeSeconds"),
            "channel_utilization": dm.get("channelUtilization"),
            "air_util_tx": dm.get("airUtilTx")
        }
    }

    write(base_path, "device", record)
    last_write[node_id] = now
