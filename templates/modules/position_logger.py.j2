import time
from modules.common_logger import write, ts

ENABLED = {{ position_enabled | default(False) }}
INTERVAL = {{ position_interval | default(300) }}

last_write = 0


def handle(packet, base_path, local_node_id):
    global last_write

    if not ENABLED:
        return

    d = packet.get("decoded", {})
    port = d.get("portnum")
    node_id = packet.get("fromId") or packet.get("from")

    if node_id != local_node_id or port != "POSITION_APP":
        return

    now = time.time()
    if now - last_write < INTERVAL:
        return

    pos = d.get("position", {})
    if not pos:
        return

    dt = ts()

    record = {
        "timestamp": dt.isoformat(),
        "type": "position",
        "node_id": node_id,
        "data": {
            "latitude": pos.get("latitude"),
            "longitude": pos.get("longitude"),
            "altitude": pos.get("altitude"),
            "sats_in_view": pos.get("satsInView"),
            "ground_speed": pos.get("groundSpeed"),
            "ground_track": pos.get("groundTrack")
        }
    }

    write(base_path, "position", record)

    last_write = now
