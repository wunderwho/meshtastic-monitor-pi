import json
import os
from datetime import datetime, timezone

def ts():
    return datetime.now(timezone.utc)

def to_local(iso):
    dt = datetime.fromisoformat(iso)
    local = dt.astimezone()
    tz = local.strftime("%Z")
    off = local.strftime("%z")
    off = f"{off[:3]}:{off[3:]}" if off else ""
    return local.strftime("%Y-%m-%d %H:%M:%S"), tz, off

def _json_safe(obj):
    if isinstance(obj, bytes):
        return obj.hex()
    if isinstance(obj, dict):
        return {k: _json_safe(v) for k, v in obj.items()}
    if isinstance(obj, list):
        return [_json_safe(v) for v in obj]
    return obj

def write(base_path, name, record):
    jp = os.path.join(base_path, f"{name}.json")
    lp = os.path.join(base_path, f"{name}.log")

    safe_record = _json_safe(record)

    with open(jp, "a") as f:
        f.write(json.dumps(safe_record) + "\n")

    ts_str, tz, off = to_local(record["timestamp"])

    parts = [f"{ts_str} {tz} ({off})", f"type={record['type']}", f"node={record['node_id']}"]
    for k, v in record["data"].items():
        parts.append(f"{k}={v if v is not None else 'None'}")

    with open(lp, "a") as f:
        f.write(" ".join(parts) + "\n")