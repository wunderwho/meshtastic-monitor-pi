import time
from modules.common_logger import write, ts

CONFIG = {"interval": {{ nodeinfo_interval | default(300) }}}
last_write = {}

def set_config(cfg):
    CONFIG.update(cfg)

def handle(packet, base_path, local_node_id):
    d = packet.get("decoded", {})
    if d.get("portnum") != "NODEINFO_APP":
        return

    node_id = packet.get("fromId") or packet.get("from")
    if node_id == local_node_id:
        return

    now = time.time()
    last = last_write.get(node_id, 0)
    if CONFIG["interval"] > 0 and (now - last) < CONFIG["interval"]:
        return

    user = d.get("user", {})

    record = {
        "timestamp": ts().isoformat(),
        "type": "nodeinfo",
        "node_id": node_id,
        "data": {
            "long_name": user.get("longName"),
            "short_name": user.get("shortName"),
            "hw_model": user.get("hwModel"),
            "role": user.get("role")
        }
    }

    write(base_path, "nodeinfo", record)
    last_write[node_id] = now
