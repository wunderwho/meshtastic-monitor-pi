import json
import time
from datetime import datetime

from meshtastic.serial_interface import SerialInterface
from pubsub import pub

LOG_FILE = "{{ monitor_home }}/environment.json"
PORT = "{{ meshtastic_port }}"

last_write = 0
INTERVAL = 300


def handle(packet, interface=None):
    global last_write

    d = packet.get("decoded", {})
    if d.get("portnum") != "TELEMETRY_APP":
        return

    env = d.get("telemetry", {}).get("environmentMetrics")
    if not env:
        return

    now = time.time()
    if now - last_write < INTERVAL:
        return

    record = {
        "timestamp": datetime.utcnow().isoformat(),
        "temperature": env.get("temperature"),
        "humidity": env.get("relativeHumidity"),
        "pressure": env.get("barometricPressure")
    }

    with open(LOG_FILE, "a") as f:
        f.write(json.dumps(record) + "\n")

    last_write = now


iface = SerialInterface(PORT)
pub.subscribe(handle, "meshtastic.receive")

while True:
    time.sleep(3600)
