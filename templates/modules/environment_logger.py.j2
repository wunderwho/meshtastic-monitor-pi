import time
from modules.common_logger import write, ts

ENABLED = {{ environment_enabled | default(True) }}
INTERVAL = {{ environment_log_interval | default(300) }}

last_write = 0


def handle(packet, base_path, local_node_id):
    global last_write

    if not ENABLED:
        return

    d = packet.get("decoded", {})
    if d.get("portnum") != "TELEMETRY_APP":
        return

    env = d.get("telemetry", {}).get("environmentMetrics")
    if not env:
        return

    now = time.time()
    if now - last_write < INTERVAL:
        return

    node_id = packet.get("fromId") or packet.get("from")

    dt = ts()

    record = {
        "timestamp": dt.isoformat(),
        "type": "environment",
        "node_id": node_id,
        "data": {
            "temperature_c": env.get("temperature"),
            "humidity_percent": env.get("relativeHumidity"),
            "pressure_hpa": env.get("barometricPressure"),
            "gas_resistance_ohm": env.get("gasResistance")
        }
    }

    write(base_path, "environment", record)

    last_write = now
