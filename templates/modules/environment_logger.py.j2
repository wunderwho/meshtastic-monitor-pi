import time
from modules.common_logger import write, ts

CONFIG = {"interval": {{ environment_log_interval | default(300) }}}
last_write = {}

def set_config(cfg):
    CONFIG.update(cfg)

def handle(packet, base_path, local_node_id):
    d = packet.get("decoded", {})
    if d.get("portnum") != "TELEMETRY_APP":
        return

    node_id = packet.get("fromId") or packet.get("from")
    if node_id != local_node_id:
        return

    now = time.time()
    last = last_write.get(node_id, 0)
    if CONFIG["interval"] > 0 and (now - last) < CONFIG["interval"]:
        return

    em = d.get("telemetry", {}).get("environmentMetrics", {})
    if not em:
        return

    record = {
        "timestamp": ts().isoformat(),
        "type": "environment",
        "node_id": node_id,
        "data": {
            "temperature_c": em.get("temperature"),
            "humidity_percent": em.get("relativeHumidity"),
            "pressure_hpa": em.get("barometricPressure"),
            "gas_resistance_ohm": em.get("gasResistance")
        }
    }

    write(base_path, "environment", record)
    last_write[node_id] = now
