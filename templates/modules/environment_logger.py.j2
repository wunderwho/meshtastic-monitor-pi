import json
import os
import time
from datetime import datetime, timezone

INTERVAL = {{ environment_log_interval | default(300) }}

last_write = 0


def handle(packet, base_path, local_node_id):
    global last_write

    d = packet.get("decoded", {})
    if d.get("portnum") != "TELEMETRY_APP":
        return

    env = d.get("telemetry", {}).get("environmentMetrics")
    if not env:
        return

    now = time.time()
    if now - last_write < INTERVAL:
        return

    temperature = env.get("temperature")
    humidity = env.get("relativeHumidity")
    pressure = env.get("barometricPressure")
    gas = env.get("gasResistance")

    ts = datetime.now(timezone.utc)

    record = {
        "timestamp": ts.isoformat(),
        "temperature_c": temperature,
        "humidity_percent": humidity,
        "pressure_hpa": pressure,
        "gas_resistance_ohm": gas
    }

    json_path = os.path.join(base_path, "environment.json")
    text_path = os.path.join(base_path, "environment.log")

    with open(json_path, "a") as f:
        f.write(json.dumps(record) + "\n")

    line = (
        f"{ts.strftime('%Y-%m-%d %H:%M:%S')} | "
        f"Temp {temperature:.2f} °C | "
        f"Humidity {humidity:.2f} % | "
        f"Pressure {pressure:.2f} hPa | "
        f"Gas {gas:.2f} Ω"
    )

    with open(text_path, "a") as f:
        f.write(line + "\n")

    last_write = now
