from modules.common_logger import write, ts

ENABLED = {{ telemetry_enabled | default(True) }}


def handle(packet, base_path, local_node_id):
    if not ENABLED:
        return

    d = packet.get("decoded", {})
    port = d.get("portnum")
    node_id = packet.get("fromId") or packet.get("from")

    if node_id != local_node_id:
        return

    if port != "NODEINFO_APP":
        return

    user = d.get("user", {})

    dt = ts()

    record = {
        "timestamp": dt.isoformat(),
        "type": "nodeinfo",
        "node_id": node_id,
        "data": {
            "long_name": user.get("longName"),
            "short_name": user.get("shortName"),
            "hw_model": user.get("hwModel"),
            "role": user.get("role")
        }
    }

    write(base_path, "telemetry", record)
