from modules.common_logger import write, ts
import time

KNOWN_PORTS = {
    "TELEMETRY_APP",
    "NODEINFO_APP",
    "TEXT_MESSAGE_APP",
    "POSITION_APP"
}

CONFIG = {"interval": {{ unknown_interval | default(0) }}}
last_write = {}

def set_config(cfg):
    CONFIG.update(cfg)

def handle(packet, base_path, local_node_id):
    d = packet.get("decoded")

    # --- IGNORE EMPTY / UNDECODED ---
    if not d:
        return

    port = d.get("portnum")

    # --- IGNORE KNOWN TYPES ---
    if port in KNOWN_PORTS:
        return

    node_id = packet.get("fromId") or packet.get("from")

    now = time.time()
    last = last_write.get(node_id, 0)
    if CONFIG["interval"] > 0 and (now - last) < CONFIG["interval"]:
        return

    record = {
        "timestamp": ts().isoformat(),
        "type": "unknown",
        "node_id": node_id,
        "data": {
            "port": port,
            "raw": d
        }
    }

    write(base_path, "unknown", record)
    last_write[node_id] = now
