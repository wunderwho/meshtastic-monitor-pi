import time
from modules.common_logger import write, ts

CONFIG = {"interval": {{ routing_interval | default(0) }}}
last_write = {}

def set_config(cfg):
    CONFIG.update(cfg)

def handle(packet, base_path, local_node_id):
    d = packet.get("decoded", {})
    if d.get("portnum") != "ROUTING_APP":
        return

    node_id = packet.get("fromId") or packet.get("from")

    now = time.time()
    last = last_write.get(node_id, 0)
    if CONFIG["interval"] > 0 and (now - last) < CONFIG["interval"]:
        return

    routing = d.get("routing", {})

    record = {
        "timestamp": ts().isoformat(),
        "type": "routing",
        "node_id": node_id,
        "data": {
            "request_id": d.get("requestId"),
            "error": routing.get("errorReason"),
            "bitfield": d.get("bitfield")
        }
    }

    write(base_path, "routing", record)
    last_write[node_id] = now